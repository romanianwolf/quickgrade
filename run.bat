@echo off
title Markov v3 - Development Server
color 0B
setlocal enabledelayedexpansion
echo.
echo  в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—
echo  в–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘
echo  в–Ҳв–Ҳв•”в–Ҳв–Ҳв–Ҳв–Ҳв•”в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘
echo  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘
echo  в–Ҳв–Ҳв•‘ в•ҡв•җв•қ в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•‘
echo  в•ҡв•җв•қ     в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ   в•ҡв•җв•қ    в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ  в•ҡв•җв•җв•җв•қ
echo.
echo  AI-Powered Grading Platform - v3.0.0
echo  ==========================================
echo.

:: в”Җв”Җв”Җ Step 1: Check Prerequisites в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo [1/6] Checking prerequisites...

where node >nul 2>&1
if errorlevel 1 (
    echo [ERROR] Node.js not found. Install from https://nodejs.org
    pause
    exit /b 1
)
for /f "tokens=*" %%v in ('node -v') do echo   Node.js: %%v

where pnpm >nul 2>&1
if errorlevel 1 (
    echo [INFO] pnpm not found. Installing...
    call npm install -g pnpm
    if errorlevel 1 (
        echo [ERROR] Failed to install pnpm
        pause
        exit /b 1
    )
)
for /f "tokens=*" %%v in ('pnpm -v') do echo   pnpm: v%%v

where git >nul 2>&1
if errorlevel 1 (
    echo [WARN] Git not found. GitHub sync will be skipped.
) else (
    echo   Git: installed
)

echo [OK] Prerequisites OK
echo.

:: в”Җв”Җв”Җ Step 2: Install Dependencies в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo [2/6] Installing dependencies...
pnpm install --frozen-lockfile 2>nul
if errorlevel 1 (
    echo [INFO] Lockfile missing or outdated, running pnpm install...
    pnpm install
)
if errorlevel 1 (
    echo [ERROR] Failed to install dependencies
    pause
    exit /b 1
)
echo [OK] Dependencies installed
echo.

:: в”Җв”Җв”Җ Step 3: Check .env.local в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo [3/6] Checking environment...
if not exist ".env.local" (
    if exist ".env.local.example" (
        echo [INFO] Creating .env.local from template...
        copy .env.local.example .env.local >nul
        echo [WARN] Edit .env.local with your API keys before grading will work.
    ) else (
        echo [WARN] No .env.local found. Create one with your environment variables.
    )
) else (
    echo [OK] .env.local found
)
echo.

:: в”Җв”Җв”Җ Step 4: Push to GitHub в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo [4/6] Syncing with GitHub...
where git >nul 2>&1
if not errorlevel 1 (
    if exist ".git" (
        git status --short
        echo.

        set /p COMMIT_MSG="Commit message (Enter to skip): "
        if not "!COMMIT_MSG!"=="" (
            git add -A
            git commit -m "!COMMIT_MSG!" 2>nul
            if not errorlevel 1 (
                echo [OK] Committed: !COMMIT_MSG!
                git push 2>nul
                if not errorlevel 1 (
                    echo [OK] Pushed to GitHub
                ) else (
                    echo [WARN] Push failed (no remote or auth issue)
                )
            ) else (
                echo [INFO] Nothing to commit
            )
        ) else (
            echo [SKIP] Skipping push
        )
    ) else (
        echo [INFO] No git repo found. Run githubrepo.bat to initialize.
    )
) else (
    echo [SKIP] Git not installed
)
echo.

:: в”Җв”Җв”Җ Step 5: Build Check в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo [5/6] Quick build check...
pnpm turbo build --filter=@markov/web 2>nul
if errorlevel 1 (
    echo [WARN] Build had warnings (non-fatal)
) else (
    echo [OK] Build OK
)
echo.

:: в”Җв”Җв”Җ Step 6: Start Dev Server в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo [6/6] Starting development server...
echo.
echo  в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
echo  в”Ӯ  Web:     http://localhost:3000          в”Ӯ
echo  в”Ӯ  Demo:    http://localhost:3000/demo     в”Ӯ
echo  в”Ӯ  API:     http://localhost:3000/api/v1/  в”Ӯ
echo  в”Ӯ  Worker:  http://localhost:3001          в”Ӯ
echo  в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
echo.

:: Start dev server in separate window
start "Markov Dev" cmd /c "pnpm turbo dev"

:: Wait for server to boot
echo  Waiting for server to start...
timeout /t 6 /nobreak >nul

:: Open browser to demo page
echo  Opening browser to demo page...
start http://localhost:3000/demo

echo.
echo  Server is running in separate window.
echo  Close that window to stop the server.
echo.
pause
