{
  "name": "markov",
  "version": "3.0.0",
  "private": true,
  "license": "MIT",
  "description": "AI-powered grading platform for schools — free, secure, open-source",
  "repository": {
    "type": "git",
    "url": "https://github.com/markov-edu/markov"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "clean": "turbo clean",
    "security:audit": "semgrep scan --config auto .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "turbo": "^2.3.3",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8",
    "@vitest/ui": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write",
      "vitest related --run"
    ],
    "*.{json,md,yml,yaml}": [
      "biome check --write"
    ]
  }
}
